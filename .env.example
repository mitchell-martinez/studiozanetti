# ─── WordPress Headless CMS ───────────────────────────────────────────────────
# URL of the WordPress instance (no trailing slash).
WORDPRESS_URL=https://cms.example.com

# Public site origin used when building canonical URLs and form-email context.
# Leave unset in local dev unless you specifically need it.
# SITE_URL=https://www.studiozanetti.com.au

# How long (in seconds) to cache WordPress REST API responses in the SSR process.
# Defaults to 60s. Set to 0 to disable caching.
WORDPRESS_CACHE_TTL_SECONDS=60

# ─── Form email delivery (SMTP) ──────────────────────────────────────────────
# The app sends form submissions over SMTP directly from the React server.
# These values are read at runtime by the form submission resource route.
#
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=mailer@example.com
# SMTP_PASS=app-password-or-smtp-password
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=Studio Zanetti
#
# Anti-spam rate limiting for form submissions (single-container in-memory store).
# FORM_RATE_LIMIT_WINDOW_MS=900000
# FORM_RATE_LIMIT_MAX_REQUESTS=5

# ─── Local development with the mock WP server ────────────────────────────────
# To run the site locally with simulated CMS data (no real WordPress needed):
#
#   1. Copy this file to .env.development.local  (already gitignored via *.local)
#      cp .env.example .env.development.local
#
#   2. Change WORDPRESS_URL to point at the mock server:
#      WORDPRESS_URL=http://localhost:8787
#
#   3. In one terminal, start the mock server:
#      npm run dev:mock
#
#   4. In a second terminal, start the React Router dev server:
#      npm run dev
#
#   The site will now load all page content from the mock server instead of
#   falling back to hardcoded defaults.  Every block type is exercised and
#   the dynamic /pricing route (created by the admin in WP) is live at
#   http://localhost:5173/pricing
