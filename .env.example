# ─── WordPress Headless CMS ───────────────────────────────────────────────────
# URL of the WordPress instance (no trailing slash).
# Set this in the Fluccs deployment dashboard.
WORDPRESS_URL=https://cms.studiozanetti.com

# How long (in seconds) to cache WordPress REST API responses in the SSR process.
# Defaults to 60s. Set to 0 to disable caching.
WORDPRESS_CACHE_TTL_SECONDS=60

# ─── Local development with the mock WP server ────────────────────────────────
# To run the site locally with simulated CMS data (no real WordPress needed):
#
#   1. Copy this file to .env.development.local  (already gitignored via *.local)
#      cp .env.example .env.development.local
#
#   2. Change WORDPRESS_URL to point at the mock server:
#      WORDPRESS_URL=http://localhost:8787
#
#   3. In one terminal, start the mock server:
#      npm run dev:mock
#
#   4. In a second terminal, start the React Router dev server:
#      npm run dev
#
#   The site will now load all page content from the mock server instead of
#   falling back to hardcoded defaults.  Every block type is exercised and
#   the dynamic /pricing route (created by Michael in WP) is live at
#   http://localhost:5173/pricing
