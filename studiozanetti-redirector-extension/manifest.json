{
  "manifest_version": 3,
  "name": "Studio Zanetti Redirector",
  "version": "1.0",
  "description": "Redirect studiozanetti.com.au links to mitchellmartinez.tech equivalent when clicked on mitchellmartinez.tech",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://studiozanetti.mitchellmartinez.tech/*",
    "https://www.studiozanetti.mitchellmartinez.tech/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://studiozanetti.mitchellmartinez.tech/*",
        "https://www.studiozanetti.mitchellmartinez.tech/*"
      ],
      "js": ["content.js"]
    }
  ]
}
